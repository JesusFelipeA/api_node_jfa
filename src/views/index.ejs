<!DOCTYPE html>
<html lang="es">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>CRUD Usuarios</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{
            font-family:'Poppins', sans-serif;
            background:#f4f7fc;
            padding:40px;
        }

        .container{
            max-width:1100px;
            margin:auto;
        }

        .card{
            background:white;
            border-radius:20px;
            padding:30px;
            box-shadow:0 10px 25px rgba(0,0,0,0.1);
        }

        h1{
            margin-bottom:25px;
            color:#1e3c72;
        }

        form{
            display:flex;
            gap:15px;
            margin-bottom:30px;
            flex-wrap:wrap;
        }

        input{
            flex:1;
            min-width:250px;
            padding:14px;
            border-radius:10px;
            border:1px solid #ccc;
            outline:none;
        }

        button{
            border:none;
            padding:14px 20px;
            border-radius:10px;
            cursor:pointer;
            font-weight:600;
            transition:0.3s;
        }

        .btn-add{
            background:#1e3c72;
            color:white;
        }

        .btn-add:hover{
            background:#294f96;
        }

        table{
            width:100%;
            border-collapse:collapse;
        }

        thead{
            background:#1e3c72;
            color:white;
        }

        th, td{
            padding:18px;
            text-align:left;
        }

        tbody tr:nth-child(even){
            background:#f7f9fc;
        }

        .actions{
            display:flex;
            gap:10px;
        }

        .edit{
            background:#ffc107;
            color:#333;
        }

        .delete{
            background:#dc3545;
            color:white;
            text-decoration:none;
        }

        .save{
            background:#28a745;
            color:white;
        }

    </style>

</head>
<body>

    <div class="container">

        <div class="card">

            <h1>CRUD Usuarios</h1>

            <!-- FORM AGREGAR -->

            <form action="/add" method="POST">

                <input
                    type="text"
                    name="nombre"
                    placeholder="Nombre"
                    required
                >

                <input
                    type="email"
                    name="email"
                    placeholder="Email"
                    required
                >

                <button class="btn-add">
                    Agregar
                </button>

            </form>

            <!-- TABLA -->

            <table>

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>

                    <% users.forEach(user => { %>

                        <tr>

                            <form
                                action="/update/<%= user.id %>"
                                method="POST"
                            >

                                <td>
                                    <%= user.id %>
                                </td>

                                <td>

                                    <input
                                        type="text"
                                        name="nombre"
                                        value="<%= user.nombre %>"
                                        required
                                    >

                                </td>

                                <td>

                                    <input
                                        type="email"
                                        name="email"
                                        value="<%= user.email %>"
                                        required
                                    >

                                </td>

                                <td>

                                    <div class="actions">

                                        <button class="save">
                                            Guardar
                                        </button>

                                        <a
                                            href="/delete/<%= user.id %>"
                                            class="delete"
                                        >
                                            Eliminar
                                        </a>

                                    </div>

                                </td>

                            </form>

                        </tr>

                    <% }) %>

                </tbody>

            </table>

        </div>

    </div>

</body>
</html>